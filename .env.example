# ──────────────────────────────────────────────
# LLM Provider Keys
# ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ──────────────────────────────────────────────
# Model Configuration
# ──────────────────────────────────────────────
CHEAP_MODEL_NAME=gpt-4o-mini
SMART_MODEL_NAME=gpt-4o
MODEL_TEMPERATURE=0.2
MAX_AGENT_RETRIES=3

# ──────────────────────────────────────────────
# Langfuse Observability
# ──────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=pk-...
LANGFUSE_SECRET_KEY=sk-...
LANGFUSE_HOST=https://cloud.langfuse.com

# ──────────────────────────────────────────────
# Pipeline Hyperparameters
# ──────────────────────────────────────────────
L0_LOWER_THRESHOLD=0.15
L0_UPPER_THRESHOLD=0.85
WINDOW_SIZE=3
FP_COST=1.0
FN_COST=5.0

# ──────────────────────────────────────────────
# RAG Configuration
# ──────────────────────────────────────────────
RAG_COLLECTION_NAME=mirror_errors
TOP_K_RAG=3
RAG_DB_PATH=./chroma_db
