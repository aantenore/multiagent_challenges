# 🪞 Project Antigravity — Configuration Template

# ── LLM Provider ──────────────────────────────────────────────
LLM_PROVIDER=gemini # openai, gemini

# ── API Keys ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...
ANTHROPIC_API_KEY=

# ── Project Antigravity Pillars ───────────────────────────────
PILLAR_FILTER_ENABLED=True
PILLAR_MEMORY_ENABLED=True
PILLAR_SQUADS_ENABLED=True
PILLAR_ORCHESTRATOR_ENABLED=True
PIPELINE_MAX_WORKERS=4
FILTER_UPPER_THRESHOLD=0.85

# ── Swarm & Squads ────────────────────────────────────────────
SWARM_MIN_AGENTS=1
SWARM_MAX_AGENTS=5
SWARM_COMPLEXITY_THRESHOLD=0.2
SWARM_TEMP_SPREAD=0.5

# ── Knowledge Store (RAG) ─────────────────────────────────────
RAG_DB_PATH=./chroma_db
TOP_K_RAG=3

# ── Observability ─────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=pk-...
LANGFUSE_SECRET_KEY=sk-...
LANGFUSE_HOST=https://cloud.langfuse.com
TEAM_NAME=A(CC)I-Tua

# ── Model Configuration (Tiers) ───────────────────────────────
# If using Gemini (LLM_PROVIDER=gemini):
GEMINI_CHEAP_MODEL_NAME=gemini-3-flash-preview
GEMINI_SMART_MODEL_NAME=gemini-3.1-pro-preview

# If using OpenAI (LLM_PROVIDER=openai):
CHEAP_MODEL_NAME=gpt-4o-mini
SMART_MODEL_NAME=gpt-4o
