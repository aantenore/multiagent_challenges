# ──────────────────────────────────────────────
# LLM Provider Selection
# ──────────────────────────────────────────────
# "openai" or "gemini" — controls which backend agents use
LLM_PROVIDER=gemini

# ──────────────────────────────────────────────
# LLM Provider Keys
# ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...

# ──────────────────────────────────────────────
# Model Configuration
# ──────────────────────────────────────────────
# OpenAI models
CHEAP_MODEL_NAME=gpt-5-mini
SMART_MODEL_NAME=gpt-5.2
# Gemini models
GEMINI_CHEAP_MODEL_NAME=gemini-3-flash-preview
GEMINI_SMART_MODEL_NAME=gemini-3.1-pro-preview
# Shared
MODEL_TEMPERATURE=0.2
MAX_AGENT_RETRIES=3

# ──────────────────────────────────────────────
# Langfuse Observability (optional)
# ──────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=pk-...
LANGFUSE_SECRET_KEY=sk-...
LANGFUSE_HOST=https://challenges.reply.com/langfuse
TEAM_NAME=A(CC)I-Tua

# ──────────────────────────────────────────────
# Layer 0 — IsolationForest One-Class Engine
# ──────────────────────────────────────────────
# IsolationForest trains on class-0 (well-being) data only.
# No user-tunable params: contamination=0.05, n_estimators=100 hardcoded.
# Inliers → pred=0 at zero LLM cost. Outliers → escalate to L1.

# ──────────────────────────────────────────────
# Pipeline Hyperparameters
# ──────────────────────────────────────────────
FP_COST=3.0
FN_COST=5.0

# ──────────────────────────────────────────────
# Swarm Configuration
# ──────────────────────────────────────────────
# Dynamic swarm scales linearly from MIN to MAX based on complexity
SWARM_MIN_AGENTS=1
SWARM_MAX_AGENTS=5
# Complexity above this threshold starts scaling (0.0-1.0)
SWARM_COMPLEXITY_THRESHOLD=0.4
# Temperature variation between swarm agents
SWARM_TEMP_SPREAD=0.50

# ── Optimization Thresholds ──────────────────────────────────────────
L1_SKIP_THRESHOLD=1.0
L2_CHEAP_MODEL_THRESHOLD=0.95

# ──────────────────────────────────────────────
# RAG Configuration
# ──────────────────────────────────────────────
RAG_COLLECTION_NAME=mirror_errors
TOP_K_RAG=5
RAG_DB_PATH=./chroma_db
