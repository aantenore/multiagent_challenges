# ──────────────────────────────────────────────
# LLM Provider Selection
# ──────────────────────────────────────────────
# "openai" or "gemini" — controls which backend agents use
LLM_PROVIDER=gemini

# ──────────────────────────────────────────────
# LLM Provider Keys
# ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...

# ──────────────────────────────────────────────
# Model Configuration
# ──────────────────────────────────────────────
# OpenAI models
CHEAP_MODEL_NAME=gpt-5-mini
SMART_MODEL_NAME=gpt-5.2
# Gemini models
GEMINI_CHEAP_MODEL_NAME=gemini-3-flash-preview
GEMINI_SMART_MODEL_NAME=gemini-3.1-pro-preview
# Shared
MODEL_TEMPERATURE=0.2
MAX_AGENT_RETRIES=3

# ──────────────────────────────────────────────
# Langfuse Observability (optional)
# ──────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=pk-...
LANGFUSE_SECRET_KEY=sk-...
LANGFUSE_HOST=https://cloud.langfuse.com

# ──────────────────────────────────────────────
# Layer 0 — Hybrid Ensemble Anomaly Detection
# ──────────────────────────────────────────────
# Z-Score σ threshold for univariate anomaly detection
ANOMALY_THRESHOLD=2.5
# Minimum temporal records to build a valid baseline
MIN_HISTORICAL_SAMPLES=3
# Ensemble weights (Z-Score vs IsolationForest)
SIGMA_WEIGHT=0.6
FOREST_WEIGHT=0.4
# IsolationForest decision_function threshold
ANOMALY_THRESHOLD_FOREST=-0.1

# ──────────────────────────────────────────────
# Pipeline Hyperparameters
# ──────────────────────────────────────────────
WINDOW_SIZE=3
FP_COST=1.0
FN_COST=5.0

# ──────────────────────────────────────────────
# Swarm Configuration
# ──────────────────────────────────────────────
# Dynamic swarm scales linearly from MIN to MAX based on complexity
SWARM_MIN_AGENTS=1
SWARM_MAX_AGENTS=5
# Complexity above this threshold starts scaling (0.0-1.0)
SWARM_COMPLEXITY_THRESHOLD=0.3
# Temperature variation between swarm agents
SWARM_TEMP_SPREAD=0.15

# ──────────────────────────────────────────────
# RAG Configuration
# ──────────────────────────────────────────────
RAG_COLLECTION_NAME=mirror_errors
TOP_K_RAG=3
RAG_DB_PATH=./chroma_db
