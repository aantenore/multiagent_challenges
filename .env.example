# ──────────────────────────────────────────────
# LLM Provider Selection
# ──────────────────────────────────────────────
# "openai" or "gemini" — controls which backend agents use
LLM_PROVIDER=gemini

# ──────────────────────────────────────────────
# LLM Provider Keys
# ──────────────────────────────────────────────
NANO_MODEL_NAME=gpt-5-nano #L0
CHEAP_MODEL_NAME=gpt-5-mini #L1
SMART_MODEL_NAME=gpt-5-mini #L2
GEMINI_NANO_MODEL_NAME=gemini-3.1-flash-lite-preview #L0
GEMINI_CHEAP_MODEL_NAME=gemini-3.1-flash-lite-preview #L1
GEMINI_SMART_MODEL_NAME=gemini-3-flash-preview #L2
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...
L0_ENGINE=isolation # isolation | llm

SWARM_MIN_AGENTS=1
SWARM_MAX_AGENTS=5
SWARM_COMPLEXITY_THRESHOLD=0.4
SWARM_TEMP_SPREAD=0.5

LANGFUSE_PUBLIC_KEY=pk-...
LANGFUSE_SECRET_KEY=sk-...
LANGFUSE_HOST=https://challenges.reply.com/langfuse
TEAM_NAME=A(CC)I-Tua
